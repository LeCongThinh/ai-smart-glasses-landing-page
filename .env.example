NEXT_PUBLIC_SITE_URL=https://your-domain.example.com

# Optional: enables Gemini Free Tier answers in the floating product chatbot.
# Create a key at https://aistudio.google.com/apikey.
# Without this key, the chatbot uses its built-in VisionAI product guide.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_CHAT_MODEL=gemini-2.5-flash-lite

# Receives JSON payloads from POST /api/newsletter (Make, Zapier, n8n, Supabase Edge Function, etc.)
NEWSLETTER_WEBHOOK_URL=https://your-webhook.example.com/newsletter

# Optional bearer token sent to the webhook.
NEWSLETTER_WEBHOOK_SECRET=replace-with-a-long-random-secret

# Optional: receives privacy-friendly click, scroll and submit events (no email/IP payload).
ANALYTICS_WEBHOOK_URL=https://your-webhook.example.com/analytics
ANALYTICS_WEBHOOK_SECRET=replace-with-a-long-random-secret
